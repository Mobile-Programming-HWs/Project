<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:context=".AddHomeworkActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:paddingStart="28dp"
        android:paddingTop="32dp"
        android:paddingEnd="28dp"
        android:paddingBottom="32dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/add_homework_title"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:lineSpacingExtra="3dp"
            android:text="@string/add_homework_subtitle"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/homework_creator"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="16sp"
            tools:text="By Teacher" />

        <EditText
            android:id="@+id/homework_description"
            android:layout_width="match_parent"
            android:layout_height="132dp"
            android:layout_marginTop="16dp"
            android:gravity="start|top"
            android:hint="Description"
            android:inputType="textMultiLine|textCapSentences"
            android:minHeight="96dp"
            android:paddingTop="12dp" />

        <EditText
            android:id="@+id/homework_link"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Download link"
            android:inputType="textUri"
            android:minHeight="56dp"
            android:singleLine="true" />

        <Button
            android:id="@+id/submit_homework"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:minHeight="52dp"
            android:text="Submit" />

    </LinearLayout>

</ScrollView>
